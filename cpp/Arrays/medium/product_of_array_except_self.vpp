
/**
Problem: Product of array except self
LeetCode: 238
Pattern: Prefix sum - array
Difficulty: Medium

Approach 1: Brute Force - 2 nested loops
Time: O(n^2)
Space: O(1)


Approach 3: Optimal Prefix sum
Time: O(n)
Space: O(1)
 */




class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        int n = nums.size();
        // vector<int>prefix(n,1);
        // for(int i = 1; i < n; i++) {
        //     prefix[i] = prefix[i-1] * nums[i-1];
        // }

        // vector<int>suffix(n,1);
        // for(int i = n-2; i>=0; i--) {
        //     suffix[i] = suffix[i+1] * nums[i+1];
        // }

        // vector<int>ans(n, 1);
        // for(int i = 0; i < n; i++) {
        //     ans[i] = prefix[i] * suffix[i];
        // }
        // return ans;


        vector<int> ans(n, 1);

        // prefix => ans
        for (int i = 1; i < n; i++) {
            ans[i] = nums[i - 1] * ans[i - 1];
        }

        int suffix = 1;
        for (int i = n - 2; i >= 0; i--) {
            suffix *= nums[i + 1]; // ith suffix
            ans[i] *= suffix;
        }

        return ans;
    }
};